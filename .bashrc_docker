# Docker 容器内的 Bash 配置
# 此文件会在进入容器时自动加载

# 加载系统默认 bashrc (如果存在)
if [ -f /etc/bash.bashrc ]; then
    source /etc/bash.bashrc
fi

# 颜色定义
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# 显示欢迎信息
echo -e "${BLUE}================================${NC}"
echo -e "${GREEN}✓ 已进入 Flutter 开发容器${NC}"
echo -e "${BLUE}================================${NC}"
echo ""

# 检查 Shorebird 登录状态
if [ -f "$HOME/.shorebird/credentials.json" ]; then
  echo -e "${GREEN}✓ Shorebird 已登录${NC}"
else
  echo -e "${YELLOW}⚠ Shorebird 未登录${NC}"
  echo -e "  运行: ${CYAN}./shorebird-helper.sh login${NC} 或 ${CYAN}shorebird login${NC}"
fi

# 检查项目是否初始化
if [ -f "shorebird.yaml" ]; then
  echo -e "${GREEN}✓ Shorebird 项目已初始化${NC}"
else
  echo -e "${YELLOW}⚠ Shorebird 项目未初始化${NC}"
  echo -e "  运行: ${CYAN}./shorebird-helper.sh init${NC} 或 ${CYAN}shorebird init${NC}"
fi

echo ""
echo -e "${BLUE}快捷命令:${NC}"
echo -e "  ${CYAN}sb${NC}               → 显示 Shorebird 帮助"
echo -e "  ${CYAN}sb login${NC}         → 登录 Shorebird"
echo -e "  ${CYAN}sb init${NC}          → 初始化项目"
echo -e "  ${CYAN}sb release [env]${NC} → 发布基础版本"
echo -e "  ${CYAN}sb patch [env]${NC}   → 推送热更新"
echo -e "  ${CYAN}sb list${NC}          → 查看发布历史"
echo ""
echo -e "${BLUE}Flutter 命令:${NC}"
echo -e "  ${CYAN}flutter build apk --dart-define=ENV=dev${NC}  → 构建 APK"
echo -e "  ${CYAN}flutter pub get${NC}                         → 安装依赖"
echo -e "  ${CYAN}flutter clean${NC}                           → 清理缓存"
echo ""
echo -e "当前工作目录: ${CYAN}/app${NC}"
echo -e "Flutter 版本: ${CYAN}$(flutter --version 2>&1 | head -1 || echo '检测失败')${NC}"
echo -e "Shorebird 版本: ${CYAN}$(shorebird --version 2>&1 | head -1 || echo '未安装')${NC}"
echo ""
echo -e "${BLUE}================================${NC}"
echo ""

# Android Build Tools PATH
export ANDROID_HOME=${ANDROID_HOME:-/opt/android}
export PATH="${PATH}:${ANDROID_HOME}/build-tools/34.0.0"

# 创建别名
alias sb='./shorebird-helper.sh'
alias flutter-build='flutter build apk --release --dart-define=ENV=dev'
alias flutter-clean='flutter clean && flutter pub get'
alias shorebird-status='shorebird account 2>/dev/null || echo "未登录Shorebird"'
alias sign-apk='./sign-apk.sh'

# 设置提示符
PS1='\[\033[01;34m\][Flutter]\[\033[00m\] \[\033[01;32m\]\w\[\033[00m\]\$ '

# 进入工作目录
cd /app
